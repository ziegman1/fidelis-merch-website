{
  "name": "fidelis-merch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env -e .env.production -e .env.vercel -e .env.local -- next dev --webpack",
    "build": "tsx scripts/build.ts",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:migrate:resolve": "node scripts/prisma-with-env.mjs migrate resolve",
    "db:execute:migration": "node scripts/prisma-with-env.mjs db execute --file prisma/migrations/20250308120000_add_product_status_and_extras/migration.sql --schema prisma/schema.prisma",
    "db:fix:production": "node scripts/apply-production-fix.mjs",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:validate": "dotenv -e .env.local -- prisma validate",
    "test:order": "dotenv -e .env.local -- tsx scripts/test-order-flow.ts",
    "test:email": "tsx scripts/test-order-email.ts",
    "test:email:label": "tsx scripts/test-order-email-with-label.ts",
    "resend:emails": "tsx scripts/resend-order-emails.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^6.9.0",
    "@vercel/blob": "^2.3.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.25",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^4.8.0",
    "stripe": "^17.4.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.9.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
