// Fidelis Merch — Prisma schema
// Multi-supplier fulfillment: dropship (Printify) + self-fulfilled

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
}

enum FulfillmentType {
  dropship
  self_fulfilled
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLING
  SHIPPED
  COMPLETE
  CANCELLED
}

enum FulfillmentStatus {
  PENDING
  SUBMITTED
  PROCESSING
  SHIPPED
  DELIVERED
  FAILED
}

enum ProviderType {
  PRINTIFY
  GENERIC
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          UserRole  @default(CUSTOMER)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// ——— Catalog ———

model Collection {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  featured    Boolean   @default(false)
  products   ProductCollection[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id               String          @id @default(cuid())
  title            String
  slug             String          @unique
  description      String?
  shortDescription String?
  fulfillmentType  FulfillmentType
  providerId       String?
  published        Boolean         @default(false) // legacy; prefer status
  status           ProductStatus   @default(DRAFT)
  publishedAt      DateTime?
  featuredImage    String?
  featured         Boolean         @default(false)
  /** Color names in thumbnail order: ["Black","Navy","Maroon","Grey"] means thumbnail 0=Black, 1=Navy, etc. */
  colorOrder       Json?
  /** ProductImage id to show as primary on storefront; when set, this image is shown first. */
  primaryImageId   String?
  /** Tags for filtering/grouping: ["featured", "apparel", "drinkware"]. Featured tag = featured item; apparel/drinkware = category. */
  tags             Json?           @default("[]")
  /** Self-fulfilled only: when true, product shows as out of stock on storefront regardless of inventory. */
  markOutOfStock   Boolean         @default(false)
  /** When true, product card is faded with "Out of stock" watermark; product page viewable but add-to-cart disabled. */
  paused           Boolean         @default(false)
  /** When true, product card is faded with "Coming Soon" watermark; product page viewable but add-to-cart disabled. */
  comingSoon       Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  provider         Provider?       @relation(fields: [providerId], references: [id], onDelete: SetNull)
  variants         ProductVariant[]
  images           ProductImage[]
  collections      ProductCollection[]
  externalMappings ExternalProductMapping[]
}

model ProductCollection {
  productId    String
  collectionId String
  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  @@id([productId, collectionId])
}

model ProductVariant {
  id           String   @id @default(cuid())
  productId    String
  sku          String?
  name         String?  // e.g. "Small / Red"
  priceCents   Int
  compareAtCents Int?
  options      Json?    // e.g. { "Size": "S", "Color": "Red" }
  sortOrder    Int      @default(0)
  active       Boolean  @default(true)
  imageOverride String?
  /** Printify/dropship only: when false, variant is out of stock at provider. Null = unknown/assume available. */
  printifyAvailable Boolean?
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory   Inventory?
  externalMappings ExternalProductMapping[]
  orderItems  OrderItem[]
}

model ProductImage {
  id         String   @id @default(cuid())
  productId  String
  url        String
  alt        String?
  sortOrder  Int      @default(0)
  variantIds Json?    // Printify variant ids this image applies to
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ——— Providers (dropship) ———

model Provider {
  id        String   @id @default(cuid())
  type      ProviderType
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  products  Product[]
  settings  ProviderSetting[]
  fulfillments Fulfillment[]
}

model ProviderSetting {
  id         String   @id @default(cuid())
  providerId String
  key        String
  value      String   // encrypted at rest if sensitive; for v1 may use env + reference only
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  @@unique([providerId, key])
}

// ——— Shipping ———

// Single default address for admin to ship international orders from (Printify is US-only).
model DefaultFulfillmentAddress {
  id           String   @id @default(cuid())
  name         String?
  line1        String?
  line2        String?
  city         String?
  state        String?
  postalCode   String?
  country      String?  @default("US")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ShippingRate {
  id         String   @id @default(cuid())
  zoneType   String   @unique // "domestic_us" | "international"
  name       String
  priceCents Int
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ExternalProductMapping {
  id                String   @id @default(cuid())
  productId         String
  productVariantId  String
  externalProductId String  // e.g. printify product id
  externalVariantId String  // e.g. printify variant id
  product           Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant  @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  @@unique([productId, productVariantId])
}

// ——— Inventory (self-fulfilled) ———

model Inventory {
  id        String   @id @default(cuid())
  variantId String   @unique
  quantity  Int      @default(0)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

// ——— Cart (optional; client-side for v1) ———
// No Cart model for v1; can add later

// ——— Checkout (cart stored server-side to avoid Stripe metadata 500-char limit) ———
model PendingCheckoutCart {
  id               String   @id @default(cuid())
  stripeSessionId  String   @unique
  cartJson         String   // full cart for order creation after payment
  createdAt        DateTime @default(now())
}

// ——— Orders ———

model Order {
  id                String      @id @default(cuid())
  stripeSessionId   String?     @unique
  stripePaymentIntentId String?
  email             String
  status            OrderStatus @default(PENDING)
  totalCents        Int
  currency          String      @default("usd")
  shippingName      String?
  shippingLine1     String?
  shippingLine2     String?
  shippingCity      String?
  shippingState     String?
  shippingPostalCode String?
  shippingCountry   String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  items             OrderItem[]
  fulfillments      Fulfillment[]
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  variantId  String
  quantity   Int
  priceCents Int
  order      Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  fulfillments FulfillmentItem[]
}

// ——— Fulfillment ———

model Fulfillment {
  id               String           @id @default(cuid())
  orderId          String
  providerId       String?
  externalOrderId  String?          // e.g. Printify order id
  status           FulfillmentStatus @default(PENDING)
  order            Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider         Provider?        @relation(fields: [providerId], references: [id], onDelete: SetNull)
  items            FulfillmentItem[]
  shipments        Shipment[]
}

model FulfillmentItem {
  id            String   @id @default(cuid())
  fulfillmentId String
  orderItemId   String
  quantity      Int
  fulfillment   Fulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  orderItem     OrderItem  @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  @@unique([fulfillmentId, orderItemId])
}

model Shipment {
  id             String   @id @default(cuid())
  fulfillmentId  String
  carrier        String?
  trackingNumber String?
  shippedAt      DateTime?
  fulfillment    Fulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
}

// ——— Analytics (storefront traffic) ———
model PageView {
  id        String   @id @default(cuid())
  path      String   // e.g. /shop, /product/foo
  referrer  String?  // full referrer URL or null
  visitorId String?  // hashed identifier for unique visitor count (privacy-safe)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
}

// ——— Editable storefront copy (admin) ———
model SiteCopy {
  id        String   @id @default("default")
  payload   Json     @default("{}")
  updatedAt DateTime @updatedAt
}
